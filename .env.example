# API key for supported direct providers (Anthropic, OpenAI, Google, Mistral)
BATEYE_LLM_MODEL_API_KEY=your-provider-api-key

# Optional fallback API key - used automatically when the primary key fails (e.g. rate limit)
BATEYE_LLM_MODEL_API_KEY_FALLBACK=

# Vercel AI Gateway credentials (required only when using vercel/* models)
AI_GATEWAY_API_KEY=your-vercel-ai-gateway-api-key
VERCEL_OIDC_TOKEN=your-vercel-oidc-token

# GitHub token - required to post PR comments when running bateye pr-review locally
GITHUB_TOKEN=your-github-token

# Repository and PR to review (used by the pr-review command; set automatically in CI)
GITHUB_REPOSITORY=owner/repo
PR_NUMBER=123

# Development / testing variables (not needed for normal usage)
# Set BATEYE_RUNTIME=mock to use fixture-based responses instead of live API calls
BATEYE_RUNTIME=
BATEYE_MOCK_RUNTIME_FIXTURES=path/to/fixtures.json
BATEYE_MOCK_RUNTIME_LOG=path/to/log.json
