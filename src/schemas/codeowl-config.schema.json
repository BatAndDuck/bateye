{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://codeowl.dev/schemas/codeowl-config.schema.json",
  "title": "CodeOwl Configuration",
  "description": "Configuration schema for .codeowl/config.json",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "model": {
      "type": "string",
      "description": "Primary analysis model in provider/model format (e.g. anthropic/claude-sonnet-4-5)",
      "examples": ["anthropic/claude-sonnet-4-5", "openai/gpt-4o"]
    },
    "apiKeyEnvVariable": {
      "type": "string",
      "description": "Name of the environment variable containing the API key",
      "examples": ["ANTHROPIC_API_KEY", "OPENAI_API_KEY"]
    },
    "exclude": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Additional paths/patterns to exclude from analysis",
      "examples": [["generated", "vendor", "proto"]]
    },
    "prReview": {
      "type": "object",
      "description": "PR review specific settings",
      "properties": {
        "autoApprove": {
          "type": "object",
          "description": "Automatically approve PRs when no findings exceed maxSeverity",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable auto-approve feature",
              "default": false
            },
            "maxSeverity": {
              "type": "string",
              "enum": ["info", "low", "medium"],
              "description": "Maximum severity that still allows auto-approve",
              "default": "low"
            }
          },
          "required": ["enabled"],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
